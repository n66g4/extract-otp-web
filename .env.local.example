# Copy this file to .env.local and set values to 'true' as required for development.

# Set to true to enable detailed debug messages in the browser console.
VITE_DEBUG_LOGGING=false

# Set to true to show QR processing output in a new tab when QR code is loaded.
VITE_DEBUG_QR_IMAGES=false

# Set to true to test jsqr --> qr-scanner fallback for single-image processing.
VITE_FORCE_JSQR_FAIL=false